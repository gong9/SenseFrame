{
  "name": "senseframe",
  "version": "0.1.1",
  "private": true,
  "description": "AI photo culling desktop app for professional photographers.",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist": "pnpm run build && electron-builder --publish never",
    "dist:mac": "pnpm run build && electron-builder --mac --publish never",
    "dist:win": "pnpm run build && electron-builder --win --publish never",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "better-sqlite3": "^12.4.1",
    "exifr": "^7.1.3",
    "lucide-react": "^0.555.0",
    "node-unrar-js": "^2.0.2",
    "openai": "^6.10.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "electron": "^39.2.7",
    "electron-builder": "^26.9.0",
    "electron-vite": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
